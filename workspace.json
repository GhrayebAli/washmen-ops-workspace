{
  "name": "Washmen Ops Workspace",
  "repos": [
    {
      "name": "ops-frontend",
      "url": "https://github.com/Washmen/react-ops-dashboard",
      "type": "frontend",
      "port": 3000,
      "dev": "NODE_OPTIONS=--openssl-legacy-provider yarn start",
      "packageManager": "yarn",
      "nodeOptions": "--openssl-legacy-provider",
      "healthPath": "/",
      "checkDir": "src"
    },
    {
      "name": "internal-public-api",
      "url": "https://github.com/Washmen/internal-public-api",
      "type": "backend",
      "port": 1345,
      "dev": "node app.js",
      "packageManager": "npm",
      "healthPath": "/",
      "isPrivate": true,
      "branch": "master"
    },
    {
      "name": "srv-internal-user-backend",
      "url": "https://github.com/Washmen/srv-internal-user-backend",
      "type": "backend",
      "port": 2339,
      "dev": "node app.js",
      "packageManager": "npm",
      "healthPath": "/",
      "isPrivate": true,
      "branch": "master"
    }
  ],
  "gitOrgs": ["Washmen", "GhrayebAli"],
  "previewPath": "/v2/",
  "repoEnvFiles": {
    "internal-public-api": {
      ".env.example": ".env"
    },
    "srv-internal-user-backend": {
      ".env.example": ".env"
    }
  },
  "envFiles": {
    "ops-frontend": {
      ".env": "REACT_APP_VERSION=$npm_package_version\nREACT_APP_NAME=$npm_package_name\nREACT_APP_GOOGLE_SERVICES_MAPS_KEY=$GOOGLE_MAPS_KEY\nREACT_APP_ALGOLIA_APP_ID=FACS2J9S09\nREACT_APP_ALGOLIA_API_KEY=$ALGOLIA_API_KEY\nREACT_APP_MUIX_LICENSE_KEY=$MUIX_LICENSE_KEY\nREACT_APP_COGNITO_LOGIN_REDIRECT_URI=http://localhost:3000/v2/auth/callback\nREACT_APP_COGNITO_LOGOUT_REDIRECT_URI=http://localhost:3000/v2/logout\nREACT_APP_COGNITO_REGION=eu-west-1\nREACT_APP_COGNITO_ENV_PREFIX=dev-\nREACT_APP_SENTRY_KEY=$SENTRY_DSN\nNODE_OPTIONS=--openssl-legacy-provider\nREACT_APP_COGNITO_CLIENT_ID=5rctrp6mo4eglq1patd2i72est\nREACT_APP_COGNITO_USER_POOL_ID=UBPxWjTx7",
      ".env.development": "REACT_APP_INTERNAL_API_OPS=http://localhost:1345/\nREACT_APP_OPS_V1_URL=https://dev-ops.washmen.com\nREACT_APP_LAUNDRY_URL=https://dev-laundry.washmen.com/\nREACT_APP_SENTRY_ENVIRONMENT=development\nREACT_APP_ENV=development\nWDS_SOCKET_HOST=0.0.0.0\nWDS_SOCKET_PORT=443\nDANGEROUSLY_DISABLE_HOST_CHECK=true",
